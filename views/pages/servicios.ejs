<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>

        <div class="p-5 mb-4 bg-light rounded-3 text-center">

            <h1>Servicios</h1>

            <table id="tabla" class="table table-striped table-hover">

                <thead>
                    <tr>
                        <th class="text-center">Nombre</th>
                        <th class="text-center">Precio</th>
                        <th class="text-center">Duración (Minutos)</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    <% servicios.forEach(function(servicio){ %>

                    <tr>

                        <td class="text-center"><%= servicio.nombre %></td>
                        <td class="text-center"><%= servicio.precio %></td>
                        <td class="text-center"><%= servicio.duracionMinutos %></td>

                        <td class="text-center">

                            <button
                                onclick="verModal('<%= servicio.nombre %>','<%= servicio.precio %>','<%= servicio.duracionMinutos %>')"
                                class="btn btn-info btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#ventanaModal">
                                VER
                            </button>

                            <button
                                onclick="editarModal('<%= servicio._id %>','<%= servicio.nombre %>','<%= servicio.precio %>','<%= servicio.duracionMinutos %>')"
                                class="btn btn-warning btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#ventanaModal">
                                EDITAR
                            </button>

                            <button
                                onclick="prepararEliminar('<%= servicio._id %>','<%= servicio.nombre %>','<%= servicio.precio %>','<%= servicio.duracionMinutos %>')"
                                class="btn btn-danger btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#ventanaModal">
                                ELIMINAR
                            </button>

                        </td>

                    </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

        <!-- Modal -->

        <div class="modal" id="ventanaModal">

            <div class="modal-dialog">

                <div class="modal-content">

                    <input type="hidden" id="idModal">

                    <div class="modal-header">

                        <h4 class="modal-title">SERVICIO</h4>

                        <button
                            type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                        </button>

                    </div>

                    <div class="modal-body">

                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input
                                type="text"
                                id="nombreModal"
                                class="form-control">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Precio</label>
                            <input
                                type="number"
                                id="precioModal"
                                class="form-control">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Duración (Minutos)</label>
                            <input
                                type="number"
                                id="duracionModal"
                                class="form-control">
                        </div>

                    </div>

                    <div class="modal-footer">

                        <button
                            id="btnGuardar"
                            class="btn btn-success"
                            onclick="guardarServicio()">
                            Guardar
                        </button>

                        <button
                            id="btnEliminar"
                            class="btn btn-info"
                            style="display:none"
                            onclick="eliminarservicio(document.getElementById('idModal').value)">
                            Eliminar
                        </button>

                        <button
                            type="button"
                            class="btn btn-danger"
                            data-bs-dismiss="modal">
                            Cerrar
                        </button>

                    </div>

                </div>

            </div>

        </div>

    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

</body>

<script>

function resetModal() {

    document.getElementById("btnGuardar").style.display = "none";
    document.getElementById("btnEliminar").style.display = "none";

    document.getElementById("nombreModal").disabled = false;
    document.getElementById("precioModal").disabled = false;
    document.getElementById("duracionModal").disabled = false;

}

function verModal(nombre, precio, duracion) {

    resetModal();

    document.getElementById("nombreModal").value = nombre;
    document.getElementById("precioModal").value = precio;
    document.getElementById("duracionModal").value = duracion;

    document.getElementById("nombreModal").disabled = true;
    document.getElementById("precioModal").disabled = true;
    document.getElementById("duracionModal").disabled = true;

}

function editarModal(id, nombre, precio, duracion) {

    resetModal();

    document.getElementById("idModal").value = id;

    document.getElementById("nombreModal").value = nombre;
    document.getElementById("precioModal").value = precio;
    document.getElementById("duracionModal").value = duracion;

    document.getElementById("btnGuardar").style.display = "inline-block";

}

async function guardarServicio() {

    const id = document.getElementById("idModal").value;

    const nombre = document.getElementById("nombreModal").value;
    const precio = document.getElementById("precioModal").value;
    const duracionMinutos = document.getElementById("duracionModal").value;

    const respuesta = await fetch("/api/ser/servicios/" + id, {

        method: "PUT",

        headers: {
            "Content-Type": "application/json"
        },

        body: JSON.stringify({
            nombre,
            precio,
            duracionMinutos
        })

    });

    if (respuesta.ok) {

        location.reload();

    } else {

        alert("Error al actualizar el servicio");

    }

}

function prepararEliminar(id, nombre, precio, duracion) {

    resetModal();

    document.getElementById("idModal").value = id;

    document.getElementById("nombreModal").value = nombre;
    document.getElementById("precioModal").value = precio;
    document.getElementById("duracionModal").value = duracion;

    document.getElementById("nombreModal").disabled = true;
    document.getElementById("precioModal").disabled = true;
    document.getElementById("duracionModal").disabled = true;

    document.getElementById("btnEliminar").style.display = "inline-block";

}

function eliminarservicio(id) {

    fetch("/api/ser/servicios/" + id, {

        method: "DELETE"

    })

    .then(res => res.json())

    .then(data => {

        alert(data.mensaje);
        location.reload();

    });

}

</script>

</html>