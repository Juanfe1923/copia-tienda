<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>

        <div class="p-5 mb-4 bg-light rounded-3 text-center">

            <h1>Productos</h1>

            <table id="tabla" class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th class="text-center">Nombre</th>
                        <th class="text-center">Precio</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    <% productos.forEach(function(producto){ %>

                        <tr>

                            <td class="text-center">
                                <%= producto.nombre %>
                            </td>

                            <td class="text-center">
                                <%= producto.precio %>
                            </td>

                            <td class="text-center">
                                <%= producto.stock %>
                            </td>

                            <td class="text-center">

                                <button
                                    onclick="verModal('<%= producto.nombre %>','<%= producto.precio %>','<%= producto.stock %>')"
                                    class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#ventanaModal">
                                    VER
                                </button>

                                <button
                                    onclick="editarModal('<%= producto._id %>','<%= producto.nombre %>','<%= producto.precio %>','<%= producto.stock %>')"
                                    class="btn btn-warning btn-sm" data-bs-toggle="modal"
                                    data-bs-target="#ventanaModal">
                                    EDITAR
                                </button>

                                <button
                                    onclick="prepararEliminar('<%= producto._id %>','<%= producto.nombre %>','<%= producto.precio %>','<%= producto.stock %>')"
                                    class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#ventanaModal">
                                    ELIMINAR
                                </button>

                            </td>

                        </tr>

                        <% }) %>

                </tbody>

            </table>

        </div>

        <!-- Modal -->

        <div class="modal" id="ventanaModal">

            <div class="modal-dialog">

                <div class="modal-content">

                    <input type="hidden" id="idModal">

                    <div class="modal-header">

                        <h4 class="modal-title">PRODUCTO</h4>

                        <button type="button" class="btn-close" data-bs-dismiss="modal">
                        </button>

                    </div>

                    <div class="modal-body">

                        <div class="mb-3">

                            <label class="form-label">Nombre</label>

                            <input type="text" id="nombreModal" class="form-control">

                        </div>

                        <div class="mb-3">

                            <label class="form-label">Precio</label>

                            <input type="number" id="precioModal" class="form-control">

                        </div>

                        <div class="mb-3">

                            <label class="form-label">Stock</label>

                            <input type="number" id="stockModal" class="form-control">

                        </div>

                    </div>

                    <div class="modal-footer">

                        <button id="btnGuardar" class="btn btn-success" onclick="guardarProducto()">
                            Guardar
                        </button>

                        <button id="btnEliminar" class="btn btn-info" style="display:none"
                            onclick="eliminarproducto(document.getElementById('idModal').value)">
                            Eliminar
                        </button>

                        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">
                            Cerrar
                        </button>

                    </div>

                </div>

            </div>

        </div>

    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

</body>

<script>

    function resetModal() {

        document.getElementById("btnGuardar").style.display = "none";
        document.getElementById("btnEliminar").style.display = "none";

        document.getElementById("nombreModal").disabled = false;
        document.getElementById("precioModal").disabled = false;
        document.getElementById("stockModal").disabled = false;

    }

    function verModal(nombre, precio, stock) {

        resetModal();

        document.getElementById("nombreModal").value = nombre;
        document.getElementById("precioModal").value = precio;
        document.getElementById("stockModal").value = stock;

        document.getElementById("nombreModal").disabled = true;
        document.getElementById("precioModal").disabled = true;
        document.getElementById("stockModal").disabled = true;

    }

    function editarModal(id, nombre, precio, stock) {

        resetModal();

        document.getElementById("idModal").value = id;

        document.getElementById("nombreModal").value = nombre;
        document.getElementById("precioModal").value = precio;
        document.getElementById("stockModal").value = stock;

        document.getElementById("btnGuardar").style.display = "inline-block";

    }

    async function guardarProducto() {

        const id = document.getElementById("idModal").value;

        const nombre = document.getElementById("nombreModal").value;
        const precio = document.getElementById("precioModal").value;
        const stock = document.getElementById("stockModal").value;

        const respuesta = await fetch("/api/pro/productos/" + id, {

            method: "PUT",

            headers: {
                "Content-Type": "application/json"
            },

            body: JSON.stringify({

                nombre,
                precio,
                stock

            })

        });

        if (respuesta.ok) {

            location.reload();

        } else {

            alert("Error al actualizar el producto");

        }

    }

    function prepararEliminar(id, nombre, precio, stock) {

        resetModal();

        document.getElementById("idModal").value = id;

        document.getElementById("nombreModal").value = nombre;
        document.getElementById("precioModal").value = precio;
        document.getElementById("stockModal").value = stock;

        document.getElementById("nombreModal").disabled = true;
        document.getElementById("precioModal").disabled = true;
        document.getElementById("stockModal").disabled = true;

        document.getElementById("btnEliminar").style.display = "inline-block";

    }

    function eliminarproducto(id) {

        fetch("/api/pro/productos/" + id, {

            method: "DELETE"

        })

            .then(res => res.json())

            .then(data => {

                alert(data.mensaje);

                location.reload();

            });

    }

</script>

</html>