<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="container">

    <header>
        <%- include('../partials/header'); %>
    </header>

    <main>
        <div class="p-5 mb-4 bg-light rounded-3 text-center">
            <h1>Clientes</h1>
            <table id="tabla" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th class="text-center">Nombre</th>
                        <th class="text-center">Telefono</th>
                        <th class="text-center">Email</th>
                        <th class="text-center">acciones</th>
                    </tr>
                </thead>

                <tbody>
                    <% clientes.forEach(function(cliente) { %>
                        <tr>
                            <td class="text-center">
                                <%= cliente.nombre %>
                            </td>
                            <td class="text-center">
                                <%= cliente.telefono %>
                            </td>
                            <td class="text-center">
                                <%= cliente.email %>
                            </td>
                            <td class="text-center">

                                <button
                                    onclick="verModal('<%= cliente.email %>','<%= cliente.telefono %>','<%= cliente.nombre %>')"
                                    class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#ventanaModal">
                                    VER</button>
                                <button
                                    onclick="editeModal('<%= cliente.email %>','<%= cliente.telefono %>','<%= cliente.nombre %>')"
                                    class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#ventanaModal">
                                    EDITAR
                                </button>
                                <button
                                    onclick="prepararEliminar('<%= cliente._id %>','<%= cliente.email %>','<%= cliente.telefono %>','<%= cliente.nombre %>')"
                                    class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#ventanaModal">
                                    ELIMINAR
                                </button>
                            </td>
                        </tr>
                        <% }); %>
                </tbody>
            </table>
        </div>


        <!-- Modal -->
        <div class="modal" id="ventanaModal">
            <div class="modal-dialog">
                <div class="modal-content">
                    <input type="hidden" id="emailOriginal">
                    <input type="hidden" id="idModal">

                    <div class="modal-header">
                        <h4 class="modal-title">CLIENTE</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" name="nombre" id="nombreModal" >
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Teléfono</label>
                            <input type="text" class="form-control" name="telefono" id="telModal">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" name="email" id="emailModal">
                        </div>
                    </div>

                    <div class="modal-footer">
                        
                        <button id="btnGuardar" class="btn btn-success" onclick="guardarCliente()">
                            Guardar
                        </button>

                        <button id="btnEliminar" class="btn btn-info" style="display:none"
                            onclick="eliminarcliente(document.getElementById('idModal').value)">
                            Eliminar
                        </button>
                        
                        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">
                            Cerrar
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </main>

    <footer>
        <%- include('../partials/footer'); %>
    </footer>

</body>
<script>

function verModal(email, telefono, nombre) {

    resetModal();

    document.getElementById("nombreModal").value = nombre;
    document.getElementById("telModal").value = telefono;
    document.getElementById("emailModal").value = email;

    document.getElementById("nombreModal").disabled = true;
    document.getElementById("telModal").disabled = true;
    document.getElementById("emailModal").disabled = true;

}

function editeModal(email, telefono, nombre) {

    resetModal();

    document.getElementById("emailOriginal").value = email;

    document.getElementById("nombreModal").value = nombre;
    document.getElementById("telModal").value = telefono;
    document.getElementById("emailModal").value = email;

    document.getElementById("btnGuardar").style.display = "inline-block";

}
async function guardarCliente() {

    const emailOriginal = document.getElementById("emailOriginal").value;

    const nombre = document.getElementById("nombreModal").value.trim();
    const telefono = document.getElementById("telModal").value.trim();
    const email = document.getElementById("emailModal").value.trim();

    if (nombre === "" || telefono === "" || email === "") {
        alert("Todos los campos son obligatorios.");
        return;
    }

    const respuesta = await fetch('/api/cli/clientes/' + emailOriginal, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            nombre,
            telefono,
            email
        })
    });

    if (respuesta.ok) {
        location.reload();
    } else {
        alert("Error al actualizar el cliente");
    }
}
function prepararEliminar(id, email, telefono, nombre) {

    resetModal();

    document.getElementById("idModal").value = id;

    document.getElementById("nombreModal").value = nombre;
    document.getElementById("telModal").value = telefono;
    document.getElementById("emailModal").value = email;

    document.getElementById("nombreModal").disabled = true;
    document.getElementById("telModal").disabled = true;
    document.getElementById("emailModal").disabled = true;

    document.getElementById("btnEliminar").style.display = "inline-block";

}

function eliminarcliente(id) { fetch(`/api/cli/clientes/${id}`, {
    method: "DELETE"
  })
  .then(res => res.json())
  .then(data => {
    alert(data.mensaje);
    location.reload();
  });
}
function resetModal() {
    document.getElementById("btnGuardar").style.display = "none";
    document.getElementById("btnEliminar").style.display = "none";

    document.getElementById("nombreModal").disabled = false;
    document.getElementById("telModal").disabled = false;
    document.getElementById("emailModal").disabled = false;
}

</script>

</html>